# =============================================
# DATABASE (Neon PostgreSQL recomendado)
# =============================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# =============================================
# NEXTAUTH
# =============================================
NEXTAUTH_URL="https://flertia.com.br"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# =============================================
# GOOGLE OAUTH (opcional)
# =============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================
# OPENAI
# =============================================
OPENAI_API_KEY="sk-proj-your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# =============================================
# UPLOADTHING
# =============================================
UPLOADTHING_SECRET="sk_live_your-uploadthing-secret"
UPLOADTHING_APP_ID="your-app-id"
UPLOADTHING_TOKEN="your-uploadthing-token"

# =============================================
# ABACATE PAY
# =============================================
ABACATEPAY_API_KEY="abc_dev_your-abacatepay-api-key"
ABACATEPAY_PRODUCT_ID="prod_your-product-id"
ABACATEPAY_WEBHOOK_SECRET="your-webhook-secret"
ABACATEPAY_BASE_URL="https://api.abacatepay.com/v2"

# =============================================
# EMAIL (SMTP)
# =============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Flert IA <noreply@flertia.com.br>"

# =============================================
# APP
# =============================================
NEXT_PUBLIC_APP_URL="https://flertia.com.br"
NEXT_PUBLIC_APP_NAME="Flert IA"
PRODUCT_PRICE_CENTS=2990
